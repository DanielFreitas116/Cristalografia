@@ -0,0 +1,20 @@
+const form = document.getElementById('bragg-form');
+const result = document.getElementById('resultado');
+
+form?.addEventListener('submit', (event) => {
+  event.preventDefault();
+
+  const n = Number(document.getElementById('n').value);
+  const lambda = Number(document.getElementById('lambda').value);
+  const thetaDeg = Number(document.getElementById('theta').value);
+
+  if (n <= 0 || lambda <= 0 || thetaDeg <= 0 || thetaDeg >= 90) {
+    result.textContent = 'Resultado: valores inválidos (use 0 < θ < 90).';
+    return;
+  }
+
+  const thetaRad = (thetaDeg * Math.PI) / 180;
+  const d = (n * lambda) / (2 * Math.sin(thetaRad));
+
+  result.textContent = `Resultado: d = ${d.toFixed(4)} Å`;
+});
